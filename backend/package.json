{
  "name": "commutepilot-backend",
  "version": "0.1.0",
  "private": true,
  "description": "CommutePilot backend core: feed ingest, enrichment, curation engine, session builder.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build-session": "tsx src/cli/buildSession.ts",
    "ingest-fixtures": "tsx src/cli/ingestFixtures.ts",
    "migrate": "tsx src/cli/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^5.9.3",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
